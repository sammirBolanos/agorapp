# Variables para conectar el backend a Neon (u otro PostgreSQL).
# Copia este archivo como "demo/.env" y rellena los valores, o exporta en la shell antes de "sh mvnw spring-boot:run".
#
# En Neon: Dashboard del proyecto → Connection string → JDBC (java).

SPRING_DATASOURCE_URL=jdbc:postgresql://TU_HOST.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Opcional: clave JWT (hex largo). En producción usa un valor fuerte y único.
# SECURITY_JWT_SECRET=
